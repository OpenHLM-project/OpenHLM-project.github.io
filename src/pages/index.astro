		background: var(--paper);
		color: var(--purple-deep);
		padding: 7px 8px;
		border-radius: 4px;
	}

	.video-slot {
		position: relative;
		overflow: hidden;
		background: #eee9f0;
		aspect-ratio: 16 / 9;
	}

	.video-slot video {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.video-unavailable {
		display: none;
		position: absolute;
		inset: 0;
		place-items: center;
		align-content: center;
		gap: 8px;
		background: linear-gradient(135deg, #f7f1fa, #eee5f4);
		color: var(--mauve-muted);
		text-align: center;
	}

	.video-unavailable strong {
		font-family: var(--font-sans);
		font-size: 30px;
		line-height: 1;
		font-weight: 700;
		color: var(--mauve-muted);
	}

	.video-unavailable span {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.video-slot.unavailable video {
		display: none;
	}

	.video-slot.unavailable .video-unavailable {
		display: grid;
	}

	.video-slot.unavailable .speed-tag {
		display: none;
	}

	.video-panel video,
	.system-card video {
		box-shadow: none;
	}

	.video-panel h3,
	.video-panel p {
		padding: 0 16px;
	}

	.video-panel h3 {
		margin-top: 16px;
		font-size: 22px;
		line-height: 1.08;
		font-weight: 600;
	}

	.video-panel p {
		margin: 10px 0 18px;
		font-size: 15px;
		line-height: 1.52;
	}

	.finding-strip {
		padding: 22px;
	}

	.finding-strip p {
		margin: 0;
		font-size: 16px;
		line-height: 1.62;
		color: var(--ink-muted);
	}

	.finding-strip p + p {
		margin-top: 16px;
	}

	.finding-strip strong {
		color: var(--purple-deep);
	}

	.vla-chart {
		position: relative;
		display: grid;
		grid-template-columns: 44px repeat(9, minmax(82px, 1fr));
		align-items: end;
		gap: 12px;
		min-height: 420px;
		padding: 46px 22px 18px;
		background:
			linear-gradient(
					to bottom,
					rgba(118, 33, 128, 0.16) 0 1px,
					transparent 1px
				)
				0 56px / 100% 70px,
			rgba(255, 255, 255, 0.46);
		overflow-x: auto;
	}

	.vla-axis {
		position: relative;
		display: block;
		align-self: end;
		height: 280px;
		margin-bottom: 66px;
		font-family: var(--font-sans);
		font-size: 12px;
		line-height: 1;
		color: var(--purple-mid);
	}

	.vla-axis span {
		position: absolute;
		right: 0;
		transform: translateY(-50%);
	}

	.vla-axis span:nth-child(1) {
		top: 0;
	}

	.vla-axis span:nth-child(2) {
		top: 25%;
	}

	.vla-axis span:nth-child(3) {
		top: 50%;
	}

	.vla-axis span:nth-child(4) {
		top: 75%;
	}

	.vla-axis span:nth-child(5) {
		top: 100%;
	}

	.vla-bar {
		display: grid;
		grid-template-rows: 1fr auto;
		gap: 12px;
		min-width: 82px;
		height: 100%;
		transition:
			opacity 160ms ease,
			filter 160ms ease;
	}

	.vla-chart.is-filtering .vla-bar {
		opacity: 0.36;
	}

	.vla-chart.is-filtering .vla-bar.is-baseline,
	.vla-chart.is-filtering .vla-bar.is-highlighted {
		opacity: 1;
		filter: saturate(1.06);
	}

	.vla-bar-plot {
		position: relative;
		height: 280px;
		align-self: end;
		border-bottom: 1px solid rgba(45, 18, 51, 0.68);
	}

	.vla-bar-fill {
		position: absolute;
		left: 50%;
		bottom: 0;
		width: min(54px, 68%);
		transform: translateX(-50%);
		background: #7b5ea7;
		border: 1px solid rgba(26, 26, 26, 0.8);
		border-bottom: 0;
		transition:
			border-color 160ms ease,
			filter 160ms ease;
	}

	.vla-bar.is-baseline .vla-bar-fill,
	.vla-bar.is-highlighted .vla-bar-fill {
		border-color: var(--purple-deep);
		filter: brightness(1.03);
	}

	.vla-bar-fill strong {
		position: absolute;
		left: 50%;
		top: -42px;
		transform: translateX(-50%);
		font-size: 14px;
		white-space: nowrap;
		color: var(--purple-deep);
	}

	.vla-error,
	.vla-error-cap {
		position: absolute;
		left: 50%;
		z-index: 2;
		background: #1a1a1a;
		transform: translateX(-50%);
	}

	.vla-error {
		width: 2px;
	}

	.vla-error-cap {
		width: 18px;
		height: 2px;
	}

	.vla-bar > span {
		min-height: 54px;
		font-size: 13px;
		line-height: 1.18;
		text-align: center;
		color: var(--purple-deep);
		font-weight: 650;
		transition: color 160ms ease;
	}

	.vla-bar.is-baseline > span {
		color: var(--purple);
	}

	.insight-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
		margin-top: 34px;
	}

	.insight-grid div {
		padding: 20px;
		border: 1px solid var(--purple-line);
		background: rgba(255, 255, 255, 0.44);
		transition:
			background 160ms ease,
			border-color 160ms ease;
	}

	.insight-grid div:hover {
		border-color: rgba(112, 64, 160, 0.52);
		background: rgba(244, 237, 248, 0.78);
	}

	.insight-grid span {
		display: block;
		font-family: var(--font-sans);
		font-weight: 700;
		color: var(--purple);
	}

	.insight-grid p {
		margin: 12px 0 0;
		font-size: 15px;
		line-height: 1.62;
	}

	.cotrain-sources {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 18px;
		margin-top: 36px;
	}

	.cotrain-source {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--purple-line);
		background: rgba(255, 255, 255, 0.48);
		overflow: hidden;
	}

	.cotrain-icon-frame {
		display: block;
		flex: 0 0 auto;
		width: 100%;
		height: clamp(220px, 24vw, 280px);
		background: rgba(246, 236, 249, 0.5);
		border-bottom: 1px solid var(--purple-line);
	}

	.cotrain-icon-frame img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		padding: 18px;
	}

	.cotrain-source > div:not(.cotrain-icon-frame) {
		flex: 1 1 auto;
		padding: 18px;
	}

	.cotrain-source h3 {
		font-size: 22px;
		line-height: 1.08;
		font-weight: 500;
	}

	.cotrain-source strong {
		display: block;
		margin-top: 12px;
		font-family: var(--font-sans);
		font-size: 12px;

		color: var(--purple);
	}

	.cotrain-source p {
		margin: 10px 0 0;
		font-size: 14px;
		line-height: 1.54;
		color: var(--ink-muted);
		text-align: left;
		text-wrap: pretty;
		hyphens: auto;
		-webkit-hyphens: auto;
	}

	.capability-matrix {
		display: grid;
		grid-template-columns: minmax(180px, 0.9fr) minmax(190px, 1.1fr) repeat(
				2,
				minmax(140px, 0.8fr)
			);
		margin-top: 34px;
		border: 1px solid var(--purple-line);
		background: rgba(255, 255, 255, 0.48);
		overflow: hidden;
	}

	.capability-matrix > div {
		min-height: 64px;
		padding: 16px;
		border-right: 1px solid var(--purple-line);
		border-bottom: 1px solid var(--purple-line);
		line-height: 1.45;
	}

	.capability-matrix > div:nth-child(4n) {
		border-right: 0;
	}

	.capability-matrix > div:nth-last-child(-n + 4) {
		border-bottom: 0;
	}

	.matrix-head {
		font-family: var(--font-sans);
		font-size: 12px;

		color: var(--purple);
		background: rgba(246, 236, 249, 0.62);
	}

	.capability-matrix strong,
	.capability-matrix span {
		display: block;
	}

	.capability-matrix span {
		margin-top: 4px;
		color: var(--ink-muted);
		font-size: 14px;
	}

	.cotrain-summary {
		display: grid;
		grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.4fr);
		gap: 34px;
		margin-top: 34px;
		padding: 22px;
		border: 1px solid var(--purple-line);
		background: rgba(255, 255, 255, 0.48);
	}

	.cotrain-summary > div:first-child span {
		display: block;
		font-family: var(--font-sans);
		font-size: 23px;
		line-height: 1.28;
		font-weight: 700;
		color: var(--purple);
	}

	.cotrain-summary > div:first-child p {
		margin: 12px 0 0;
		font-size: 15px;
		line-height: 1.58;
		color: var(--ink-muted);
	}

	.cotrain-bars {
		display: grid;
		gap: 14px;
	}

	.cotrain-bar > div:first-child {
		display: flex;
		justify-content: space-between;
		gap: 14px;
	}

	.cotrain-bar strong {
		font-size: 15px;
		color: var(--purple-deep);
		font-weight: 700;
	}

	.cotrain-bar span {
		font-family: var(--font-sans);
		font-size: 22px;
		line-height: 1;
		color: var(--purple-deep);
	}

	.cotrain-progress-track {
		position: relative;
		display: block;
		height: 9px;
		margin-top: 8px;
		border-radius: 999px;
		background: var(--progress-track);
		overflow: hidden;
	}

	.cotrain-progress-track::after {
		content: "";
		position: absolute;
		inset: 0 auto 0 0;
		width: var(--progress-fill, 0%);
		height: 100%;
		background: var(--progress-gradient);
		border-radius: 999px;
	}

	.cotrain-bar p {
		margin: 6px 0 0;
		font-size: 13px;
		line-height: 1.4;
		color: var(--ink-muted);
	}

	.wide-note {
		padding: 22px 24px;
	}

	.wide-note p {
		margin: 0;
	}

	.bibtex-block {
		margin: 30px 0 0;
		padding: 22px 24px;
		border: 1px solid var(--purple-line);
		border-radius: 4px;
		background: rgba(246, 236, 249, 0.62);
		color: var(--purple-deep);
		overflow-x: auto;
		white-space: pre;
	}

	.bibtex-block code {
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono",
			monospace;
		font-size: 14px;
		line-height: 1.62;
	}

	.system-card {
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	.system-video-frame,
	.wild-video-frame {
		position: relative;
		overflow: hidden;
		border-radius: 4px;
		background: #f2edf6;
	}

	.system-copy {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 16px;
	}

	.method-title {
		font-weight: 500;
	}

	.method-title-featured {
		color: var(--purple);
		font-weight: 700;
	}

	.method-title-sub {
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono",
			monospace;
		font-size: 0.76em;
		font-weight: 400;
		letter-spacing: 0;
	}

	.system-card video,
	.system-video-frame {
		border-radius: 0;
	}

	.system-copy p {
		margin: 10px 0 0;
		font-size: 14px;
		line-height: 1.52;
	}

	.system-metrics {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 0;
	}

	.system-metrics span {
		padding: 7px 9px;
		border: 1px solid var(--purple-line);
		border-radius: 4px;
		background: #f5edf8;
		font-size: 12px;
		color: var(--purple);
	}

	.system-progress {
		margin-top: auto;
		padding-top: 18px;
	}

	.system-progress > div:first-child {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
	}

	.system-progress span {
		font-family: var(--font-sans);
		font-size: 12px;

		color: var(--purple);
	}

	.system-progress strong {
		font-family: var(--font-sans);
		font-size: 24px;
		line-height: 1;
		color: var(--purple-deep);
	}

	.system-progress-track {
		position: relative;
		display: block;
		width: 100%;
		height: 10px;
		margin-top: 10px;
		background: var(--progress-track);
		overflow: hidden;
		border-radius: 999px;
	}

	.system-progress-track::after {
		content: "";
		position: absolute;
		inset: 0 auto 0 0;
		width: var(--progress-fill, 0%);
		height: 100%;
		background: var(--progress-gradient);
		border-radius: 999px;
	}

	.wild-section {
		padding-bottom: 30px;
	}

	.wild-video {
		margin-top: 36px;
		width: min(900px, calc(100vw - 36px));
		margin-left: auto;
		margin-right: auto;
	}

	.wild-video video {
		border: 1px solid rgba(102, 8, 116, 0.2);
	}

	.wild-video strong {
		display: block;
		margin-top: 14px;
		font-family: var(--font-sans);
		font-size: clamp(26px, 3vw, 38px);
		line-height: 1.08;
		font-weight: 500;
	}

	.wild-video p {
		margin: 18px 0 0;
	}

	@media (max-width: 1180px) {
		.floating-toc {
			position: fixed;
			top: 18px;
			right: 18px;
			width: auto;
			max-width: calc(100vw - 220px);
		}
	}

	@media (max-width: 980px) {
		.floating-toc {
			position: static;
			width: auto;
			margin: 22px 18px 0 auto;
			max-width: 360px;
		}

		.task-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			width: min(820px, calc(100vw - 36px));
			gap: 14px;
		}

		.stat-band,
		.video-comparison,
		.system-videos,
		.cotrain-sources,
		.insight-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.cotrain-summary {
			grid-template-columns: 1fr;
		}

		.vla-chart {
			grid-template-columns: 40px repeat(9, minmax(74px, 1fr));
			gap: 10px;
			padding: 44px 18px 18px;
			-webkit-overflow-scrolling: touch;
		}

		.vla-bar {
			min-width: 74px;
		}

		.vla-bar-fill {
			width: min(48px, 68%);
		}

		.metric-grid {
			grid-template-columns: minmax(170px, 1fr) repeat(
					3,
					minmax(126px, 1fr)
				);
			overflow-x: auto;
		}

		.wild-video {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 680px) {
		.sticky-nav {
			display: none;
		}

		.brand {
			flex: 0 0 auto;
			margin-right: 10px;
		}

		.sticky-nav-links {
			flex: 1 1 auto;
			min-width: 0;
			overflow-x: auto;
			overscroll-behavior-x: contain;
			scrollbar-width: none;
		}

		.sticky-nav-links::-webkit-scrollbar {
			display: none;
		}

		.sticky-nav-links a {
			flex: 0 0 auto;
			padding: 8px 9px;
			white-space: nowrap;
		}

		.topbar,
		.hero,
		.stat-band,
		.content {
			padding-left: 18px;
			padding-right: 18px;
		}

		.hero {
			min-height: 100svh;
			min-height: 100dvh;
			padding-top: 66px;
			padding-bottom: 48px;
		}

		h1 {
			margin-top: 18px;
			font-size: clamp(24px, 7vw, 32px);
			line-height: 1.16;
		}

		h1 .purple {
			margin-bottom: 10px;
			font-size: clamp(58px, 18vw, 88px);
			line-height: 1;
		}

		h2 {
			font-size: clamp(24px, 8vw, 32px);
			line-height: 1.14;
		}

		h3 {
			font-size: 22px;
		}

		.paper-section {
			scroll-margin-top: 66px;
			padding: 64px 0 68px;
		}

		.paper-section:last-child {
			padding-bottom: 34px;
		}

		.overview {
			padding-top: 64px;
		}

		.paper-section > p:not(.section-kicker),
		.chart-head p,
		.video-panel p,
		.insight-grid p,
		.wide-note p,
		.system-copy p,
		.wild-video p {
			font-size: 16px;
			line-height: 1.62;
		}

		.hero-actions {
			gap: 12px;
			margin-top: 28px;
		}

		.hero-link {
			flex: 1 1 calc(50% - 6px);
			min-width: 132px;
			min-height: 50px;
			padding: 0 16px;
			font-size: 17px;
		}

		.stat-band,
		.video-comparison,
		.system-videos,
		.insight-grid,
		.finding-strip,
		.cotrain-sources,
		.cotrain-summary {
			grid-template-columns: 1fr;
		}

		.task-grid {
			grid-template-columns: 1fr;
			width: min(480px, calc(100vw - 36px));
			margin-top: 32px;
		}

		.pipeline-transition {
			margin-top: 34px !important;
		}

		.teaser-figure {
			margin-top: 28px;
		}

		.cotrain-icon-frame {
			height: 220px;
		}

		.video-comparison,
		.system-videos,
		.wild-video {
			width: min(560px, calc(100vw - 36px));
		}

		.video-panel h3,
		.system-copy h3,
		.cotrain-source h3 {
			font-size: 21px;
		}

		.vla-chart {
			grid-template-columns: 36px repeat(9, minmax(68px, 1fr));
			gap: 8px;
			min-height: 390px;
			padding: 42px 14px 16px;
		}

		.vla-axis {
			font-size: 11px;
		}

		.vla-bar {
			min-width: 68px;
		}

		.vla-bar > span {
			font-size: 12px;
		}

		.cotrain-summary > div:first-child span {
			font-size: 21px;
		}

		.capability-matrix {
			grid-template-columns: repeat(4, minmax(160px, 1fr));
			overflow-x: auto;
		}

		.chart-head {
			align-items: start;
			grid-template-columns: 1fr;
			gap: 18px;
			padding: 18px;
		}

		.chart-head > div:not(.task-selector) {
			order: 0;
		}

		.task-selector {
			justify-self: stretch;
			width: 100%;
		}

		.metric-grid {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			grid-template-rows: none;
			overflow: hidden;
			border-top: 1px solid var(--purple-line);
		}

		.grid-label:first-child {
			display: none;
		}

		.grid-label.metric {
			min-height: 58px;
			justify-items: center;
			padding: 10px 6px;
			background: rgba(246, 236, 249, 0.62);
			text-align: center;
			border-right: 1px solid var(--purple-line);
		}

		.grid-label.metric:nth-child(4) {
			border-right: 0;
		}

		.grid-label.metric span {
			font-size: 14px;
		}

		.grid-label.metric small {
			font-size: 11px;
			line-height: 1.15;
		}

		.method-cell {
			grid-column: 1 / -1;
			min-height: auto;
			padding: 12px 14px;
			background: #efe3f5;
			border-right: 0;
		}

		.metric-cell {
			min-height: 78px;
			justify-items: start;
			padding: 12px 8px;
			text-align: left;
			border-right: 1px solid var(--purple-line);
		}

		.metric-cell:nth-child(4n) {
			border-right: 0;
		}

		.metric-value {
			font-size: 21px;
		}

		.metric-cell i {
			width: 100%;
		}

		.task-card {
			/* grid handles sizing */
		}
	}

	@media (max-width: 440px) {
		.sticky-nav {
			padding-left: 12px;
			padding-right: 8px;
		}

		.brand {
			font-size: 12px;
		}

		.sticky-nav-links a {
			padding: 8px;
