		color: var(--purple);
	}

	.sticky-nav-links {
		display: flex;
		position: relative;
		z-index: 1;
		align-items: center;
		gap: 6px;
		height: 56px;
	}

	.sticky-nav-links a {
		padding: 9px 12px;
		border: 1px solid transparent;
