---

<Layout>
	<main class="site-shell" id="top">
		<nav class="sticky-nav" aria-label="Site navigation">
			<a href="#top" class="brand">OpenHLM</a>
			<div class="sticky-nav-links">
				{toc.map((item) => <a href={item.href}>{item.label}</a>)}
			</div>
		</nav>

		<header class="hero">
			<video
				class="hero-bg-video"
				autoplay
				muted
				loop
				playsinline
				preload="metadata"
				src={withBase("openhlm/video/OpenHLM.mp4")}></video>
			<div class="hero-overlay"></div>
			<section class="title-block">
				<h1 style="text-align: center;">
					<span class="purple">OpenHLM</span>
					<span>An Empirical Recipe for Whole-Body</span><br />
					<span>Humanoid Loco-Manipulation</span>
				</h1>
				<div class="authors">
					{
						authorRows.map((row) => (
							<p class="author-list">
								{row.map((author, index) => (
									<span class="author">
										{author.url ? (
											<a
												class="author-link"
												href={author.url}
												target="_blank"
												rel="noopener noreferrer"
											>
												{author.name}
											</a>
										) : (
											author.name
										)}
										<sup>
											{author.affil}
											{author.marks.join("")}
										</sup>
										{index < row.length - 1 && (
											<span class="author-sep"> </span>
										)}
									</span>
								))}
							</p>
						))
					}
					<p class="affiliation-list">
						{
							affiliations.map((affil) => (
								<span class="affiliation">
									<sup>{affil.id}</sup>
									{affil.name}
								</span>
							))
						}
					</p>
					<p class="author-notes">
						{
							authorNotes.map((note) => (
								<span class="author-note">
									<sup>{note.mark}</sup>
									{note.text}
								</span>
							))
						}
					</p>
				</div>
				<div class="hero-actions">
					{
						heroLinks.map((link) => (
							<a
								class="hero-link"
								href={link.href}
								aria-label={link.label}
							>
								<span
									class={`hero-link-icon ${link.icon}`}
									aria-hidden="true"
								>
									<img
										src={link.iconUrl}
										alt=""
										width="24"
										height="24"
										style="display: block;"
									/>
								</span>
								<span>{link.label}</span>
							</a>
						))
					}
				</div>
			</section>
		</header>
		<div class="hero-divider"></div>

		<article class="content">
			<section class="paper-section wild-section" id="wild">
				<h2>A humanoid in the wild</h2>
				<p>
					<span class="purple"><strong>OpenHLM</strong></span> is a recipe
					for whole-body humanoid loco-manipulation: it maps a language
					instruction and the robot's observation images into coordinated
					motion across every one of the robot's degrees of freedom.
				</p>
				<p>
					So what can it do? Mix in just 20 outdoor demos with our lab
					data, and the humanoid moonlights as the campus janitor—<strong
						>fully autonomous, outdoors, no mocap</strong
					>. As far as we know, no humanoid has done this in the wild
					before.
				</p>

				<div class="wild-video">
					<div class="wild-video-frame">
						<video
							autoplay
							muted
							loop
							playsinline
							controls
							preload="metadata"
							src={withBase(
								"openhlm/video/ablation/outside_spirit_disposal.mp4",
							)}></video>
						<span class="speed-tag">autonomous 2x</span>
					</div>
				</div>
			</section>
			<section class="paper-section" id="system_comparison">
				<h2>Comparison with SOTA</h2>
				<p>
					How does OpenHLM stack up against other humanoid VLAs? We
					compare at the system level with two representative
					baselines: <strong>GR00T N1.6</strong> and <strong
						>Ψ₀</strong
					>.
				</p>
				<p>
					The evaluation is a challenging long-horizon task: the robot
					walks between a low table, a medium table, and a tall shelf,
					picking two language-specified fruits—one per hand—and
					placing them into separate containers. This spans the
					humanoid's full vertical workspace and requires language
					grounding across 20 ordered fruit pairs. OpenHLM reaches
					87.5% task progress using <strong
						>less than half the demonstration time</strong
					> of either baseline.
				</p>

				<div class="system-videos">
					{
						systemMethods.map((method) => (
							<section class="system-card">
								<div class="system-video-frame">
									<video
										autoplay
										muted
										loop
										playsinline
										controls
										preload="metadata"
										src={withBase(method.src)}
									/>
									<span class="speed-tag">autonomous 2x</span>
								</div>
								<div class="system-copy">
									<h3
										class={
											method.name ===
											"OpenHLM (HuMI Co-Training)"
												? "method-title method-title-featured"
												: "method-title"
										}
									>
										{method.name ===
										"OpenHLM (HuMI Co-Training)" ? (
											<>
												OpenHLM{" "}
												<span class="method-title-sub">
													(HuMI Co-Training)
												</span>
											</>
										) : (
											method.name
										)}
									</h3>
									<div class="system-metrics">
										<span>
											{nbspUnit(method.time)} demo time
										</span>
									</div>
									<div class="system-progress">
										<div>
											<span>Task Progress</span>
											<strong>{method.progress}%</strong>
										</div>
										<div
											class="system-progress-track"
											style={`--progress-fill: ${method.progress}%`}
										/>
									</div>
								</div>
							</section>
						))
					}
				</div>
			</section>

			<section class="paper-section" id="benchmark">
				<h2>HLM Tasks</h2>
				<p>
					Want more tasks? We introduce 12 language-conditioned tasks
					that target different aspects of whole-body
					loco-manipulation behavior, organized into four categories: <strong
						class="family-mark family-pick-place"
						data-family="pick-place"
						tabindex="0">(1) pick-and-place with locomotion</strong
					>, <strong
						class="family-mark family-workspace"
						data-family="workspace"
						tabindex="0">(2) whole-body workspace extension</strong
					>, <strong
						class="family-mark family-body"
						data-family="body"
						tabindex="0"
						>(3) using body parts as manipulators</strong
					>, and
					<strong
						class="family-mark family-constraint"
						data-family="constraint"
						tabindex="0"
						>(4) loco-manipulation under environmental constraints</strong
					>. OpenHLM achieves strong performance across all 12 tasks,
					with <strong>average task progress exceeding 90%</strong>.
				</p>

				<div class="task-grid bleed">
					{
						benchmarkTasks.map((task, index) => (
							<section
								class="task-card"
								data-family={getTaskFamilyClass(task.family)}
							>
								<div
									class={`task-video family-${getTaskFamilyClass(
										task.family,
									)}`}
								>
									<video
										autoplay
										muted
										loop
										playsinline
										controls
										preload="metadata"
										src={withBase(task.file)}
									/>
									<span class="family-tag">
										{getTaskFamilyLabel(task.family)}
									</span>
									<span class="speed-tag">autonomous 2x</span>
								</div>
								<h3>{task.title}</h3>
								<p>{String(index + 1).padStart(2, "0")} / 12</p>
							</section>
						))
					}
				</div>
			</section>

			<section class="paper-section overview">
				<h2>How did we get here?</h2>
				<p>
					None of this comes from a single trick. We construct
					<span class="purple"><strong>OpenHLM</strong></span> through controlled
					experiments, one design decision at a time, in three phases that
					build up to a concrete recipe for whole-body humanoid loco-manipulation.
				</p>
				<p>
					<strong>Low-level controller and teleoperation:</strong> how to
					design the controller and its teleop interface for high-quality
					whole-body demonstrations.
					<strong>Whole-body VLA policy design:</strong> which adaptations
					turn a VLA built for static and wheeled robots into a whole-body
					humanoid policy.
					<strong>Heterogeneous co-training:</strong> whether cheaper data
					sources can extend the policy beyond what whole-body teleop alone
					covers.
				</p>
				<img
					class="teaser-figure"
					src={withBase("openhlm/image/teaser.png")}
					width="1066"
					height="426"
					alt="OpenHLM teaser figure"
				/>
			</section>

			<section class="paper-section" id="controller">
				<h2>Low-level controller and teleoperation</h2>
				<p>
					We follow a <strong
						>two-level hierarchical control framework</strong
					>: a high-level policy (the operator during data collection,
					the learned VLA at deployment) emits reference whole-body
					commands, and a lightweight low-level controller tracks
					them. With this framework fixed, the interface between the
					two determines both what the operator can express and what
					action space the VLA learns.
				</p>
				<p>
					We compare three teleoperation methods representative of
					recent humanoid systems: <strong>decoupled control</strong>
					(dual-arm IK plus an RL lower-body controller tracking a base-velocity
					and root-height command, 21-D), <strong>VR 3-point</strong> (head
					and wrist poses plus a navigation command, 24-D), and
					<strong>joint-based whole-body teleoperation</strong> (a portable
					motion-capture rig retargeted in real time to every humanoid joint,
					32-D). We collect matched demonstrations under each interface
					and train one VLA per method.
				</p>

				<div class="interactive-table" data-teleop-chart>
					<div class="chart-head">
						<div
							class="task-selector"
							role="group"
							aria-label="Task selector"
						>
							{
								teleopTasks.map((task, index) => (
									<button
										class={index === 0 ? "active" : ""}
										type="button"
										data-task-option={task.key}
									>
										{task.label}
									</button>
								))
							}
						</div>
						<div>
							<h3>Teleop Method Comparison</h3>
							<p>
								Select a task to compare task progress, rollout
								time, and footsteps. N/A marks tasks the
								interface cannot express by construction.
							</p>
						</div>
					</div>

					<div class="metric-grid">
						<div class="grid-label">Method</div>
						{
							metricColumns.map((metric) => (
								<div class="grid-label metric">
									<span>{metric.label}</span>
									<small>{metric.hint}</small>
								</div>
							))
						}
						{
							teleopRows.map((row) => (
								<>
									<div
										class={`method-cell ${row.ours ? "is-ours" : ""}`}
									>
										{row.method}
										{row.ours && (
											<span class="ours-tag">(Ours)</span>
										)}
									</div>
									{metricColumns.map((metric) => (
										<div
											class={`metric-cell ${row.ours ? "is-ours" : ""}`}
											data-cell
											data-values={JSON.stringify(
												Object.fromEntries(
													teleopTasks.map((task) => [
														task.key,
														row.values[task.key]?.[
															metric.key
														] ?? "",
													]),
												),
											)}
											data-unit={metric.unit}
											data-max={metric.max}
										>
											<span class="metric-value" />
											<i />
										</div>
									))}
								</>
							))
						}
					</div>
				</div>

				<div class="video-comparison">
					{
						teleopMethods.map((method) => (
							<section class="video-panel" data-video-panel>
								<div class="panel-topline">
									<span>{method.action}</span>
									<span data-panel-task>Cola Placement</span>
								</div>
								<div
									class="video-slot"
									data-video-map={JSON.stringify(
										Object.fromEntries(
											teleopTasks.map((task) => [
												task.key,
												withBaseIfPresent(
													method.videos.find(
														(video) =>
															video.title ===
															task.label,
													)?.src,
												),
											]),
										),
									)}
								>
									<video
										autoplay
										muted
										loop
										playsinline
										controls
										preload="metadata"
									/>
									<div
										class="video-unavailable"
										aria-hidden="true"
									>
										<strong>N/A</strong>
										<span>Not Supported</span>
									</div>
									<span class="speed-tag">autonomous 2x</span>
								</div>
								<h3>{method.compact}</h3>
							</section>
						))
					}
				</div>
				<p>
					The numbers tell a clear story.
					<strong>Joint-based whole-body teleoperation</strong> is the only
					interface that completes all three tasks. The two alternatives
					expose only a subset of the humanoid's degrees of freedom, so
					tasks like a foot depressing a pedal or the whole body squatting
					under a shelf are unreachable by construction. Based on these
					results, we adopt joint-based whole-body teleoperation as the
					data-collection interface that all later phases build on.
				</p>
			</section>

			<section class="paper-section" id="policy">
				<h2>Whole-body VLA policy design</h2>
				<p>
					Existing VLAs bring vision-language reasoning and
					manipulation priors, but nearly all target static or wheeled
					dual-arm platforms—none were designed for humanoid
					loco-manipulation. So how do we adapt one into a whole-body
					humanoid policy, and which design choices actually matter?
					We organize the exploration into three families: the <em
						>action and proprioception interface</em
					>, the <em>role of pretraining</em>, and
					<em>faster action generation</em>—ablating one component at
					a time on a 4-task subset.
				</p>

				<div class="vla-chart" aria-label="VLA design ablations">
					<div class="vla-axis" aria-hidden="true">
						<span>100</span>
						<span>75</span>
						<span>50</span>
						<span>25</span>
						<span>0</span>
					</div>
					{
						vlaBars.map((item) => (
							<div
								class={`vla-bar ${item.label.startsWith("Ours") ? "is-baseline" : ""}`}
								data-group={item.group}
							>
								<div class="vla-bar-plot">
									<i
										class="vla-error"
										style={`bottom: ${item.value - item.sem}%; height: ${item.sem * 2}%`}
									/>
									<i
										class="vla-error-cap bottom"
										style={`bottom: ${item.value - item.sem}%`}
									/>
									<i
										class="vla-error-cap top"
										style={`bottom: ${item.value + item.sem}%`}
									/>
									<div
										class="vla-bar-fill"
										style={`height: ${item.value}%; background: ${item.color}`}
									>
										<strong>
											{item.value.toFixed(1)}%
										</strong>
									</div>
								</div>
								<span>{item.label}</span>
							</div>
						))
					}
				</div>

				<div class="insight-grid">
					<div data-insight="interface">
						<span>Interface Adaptations Barely Matter</span>
						<p>
							Adapting π₀.₅'s action space to the humanoid
							involves four choices: projection initialization,
							action ordering, absolute vs. relative targets, and
							proprioceptive input. Flipping any one produces only
							a slight drop—no single choice is the bottleneck.
						</p>
					</div>
					<div data-insight="pretraining">
						<span>Non-Humanoid Pretraining Transfers</span>
						<p>
							Initialized from π₀.₅ (pretrained on dual-arm
							robots), the policy reaches 91% task progress;
							PaliGemma (same architecture, vision-language only)
							drops to 60%; random init collapses to 42%. The
							cross-embodiment gap is real, but dwarfed by the gap
							between any robot pretraining and none.
						</p>
					</div>
					<div data-insight="inference">
						<span>Multi-Step Inference Wins</span>
						<p>
							Counterintuitively, both one-step alternatives reach
							<em>lower</em> validation action MSE than π₀.₅'s 10-step
							flow matching—yet on the robot they underperform it by
							~20 task-progress points. So we keep multi-step inference.
						</p>
					</div>
				</div>
			</section>

			<section class="paper-section" id="cotrain">
				<h2>Heterogeneous co-training</h2>
				<p>
					With the whole-body VLA established, scaling to every task
					through loco-manipulation teleop is expensive. We turn to
					two cheaper data sources and ask whether co-training can
					incorporate them effectively: <strong
						>stationary teleoperation</strong
					> (the same humanoid with feet planted, manipulation only) and
					<strong>HuMI</strong> (robot-free demonstrations captured with
					low-cost wearable devices). The question is whether either can
					extend the policy to held-out tasks that whole-body teleop never
					covers.
				</p>

				<div
					class="cotrain-sources"
					aria-label="Co-training data sources"
				>
					{
						cotrainSources.map((source) => (
							<section class="cotrain-source">
								<div class="cotrain-icon-frame">
									<img
										src={withBase(source.image)}
										alt={`${source.label} illustration`}
										width="512"
										height="512"
									/>
								</div>
								<div>
									<h3>{source.label}</h3>
									<strong>{nbspUnit(source.cost)}</strong>
									<p>{source.detail}</p>
								</div>
							</section>
						))
					}
				</div>

				<div class="cotrain-summary">
					<div>
						<span>
							Task Progress<br />
							on Held-Out Tasks 9–11
						</span>
						<p>
							With the policy trained on whole-body teleop for
							Tasks 1–8, we co-train it with cheaper data on three
							held-out tasks (9–11) that whole-body teleop never
							covers. Both streams lift average progress on these
							tasks from 36% to near the oracle—with no extra
							whole-body teleop.
						</p>
					</div>
					<div class="cotrain-bars">
						{
							cotrainBars.map((item) => (
								<div class="cotrain-bar">
									<div>
										<strong>{item.label}</strong>
										<span>{item.value}%</span>
									</div>
									<div
										class="cotrain-progress-track"
										style={`--progress-fill: ${item.value}%`}
									/>
									<p>{item.detail}</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="paper-section" id="citation">
				<h2>Citation</h2>
				<p>
					If you find OpenHLM useful in your research, please cite our
					work:
				</p>
				<div class="bibtex-wrapper">
					<pre class="bibtex-block"><code>{bibtexCitation}</code></pre>
				</div>
			</section>
		</article>
	</main>
</Layout>

<script is:inline>
	const reduceMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;

	const setVideoSpeed = (video) => {
		const rate = video.classList.contains("hero-bg-video") ? 1 : 2;
		video.defaultPlaybackRate = rate;
		video.playbackRate = rate;
	};

	const startMutedVideos = () => {
		document.querySelectorAll("video").forEach((video) => {
			video.muted = true;
			video.playsInline = true;
			setVideoSpeed(video);
			video.play().catch(() => {});
		});
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", startMutedVideos, {
			once: true,
		});
	} else {
		startMutedVideos();
	}

	const nav = document.querySelector(".sticky-nav");
	const updateNavTone = () => {
		if (!nav) return;
		const threshold = Math.max(320, window.innerHeight * 0.9);
		const fadeStart = Math.max(72, window.innerHeight * 0.08);
		const fadeEnd = Math.max(150, window.innerHeight * 0.25);
		const isScrolled = window.scrollY > threshold;
		const fadeProgress = Math.min(
			1,
			Math.max(0, (window.scrollY - fadeStart) / (fadeEnd - fadeStart)),
		);
		const heroOpacity = isScrolled ? 1 : 1 - fadeProgress;
		nav.classList.toggle("nav-scrolled", isScrolled);
		nav.style.setProperty("--nav-opacity", String(heroOpacity));
		nav.style.setProperty(
			"--nav-pointer",
			heroOpacity < 0.08 && !isScrolled ? "none" : "auto",
		);
	};
	updateNavTone();
	window.addEventListener("resize", updateNavTone, { passive: true });
	window.addEventListener("scroll", updateNavTone, { passive: true });

	const navLinks = [...document.querySelectorAll(".sticky-nav-links a")];
	const navSections = navLinks
		.map((link) => {
			const id = link.getAttribute("href")?.slice(1);
			const section = id ? document.getElementById(id) : null;
			return section ? { link, section } : null;
		})
		.filter(Boolean);
	let navJumpInProgress = false;

	const updateActiveNavLink = () => {
		if (navJumpInProgress) return;
		const probeY = window.scrollY + window.innerHeight * 0.36;
		let active = null;
		navSections.forEach((item) => {
			if (item.section.offsetTop <= probeY) {
				active = item;
			}
		});

		navLinks.forEach((link) => {
			link.classList.toggle("active", active?.link === link);
		});
	};
	updateActiveNavLink();
	window.addEventListener("resize", updateActiveNavLink, { passive: true });
	window.addEventListener("scroll", updateActiveNavLink, { passive: true });
	navSections.forEach(({ link, section }) => {
		link.addEventListener("click", (event) => {
			event.preventDefault();
			navJumpInProgress = true;
			const navOffset = nav?.offsetHeight || 0;
			const targetY = Math.max(
				0,
				section.getBoundingClientRect().top +
					window.scrollY -
					navOffset -
					20,
			);
			history.pushState(null, "", link.getAttribute("href"));
			navLinks.forEach((item) => {
				item.classList.toggle("active", item === link);
			});
			window.scrollTo({ top: targetY, behavior: "smooth" });
			updateNavTone();

			const finishJump = () => {
				navJumpInProgress = false;
				navLinks.forEach((item) => {
					item.classList.toggle("active", item === link);
				});
				window.removeEventListener("scrollend", finishJump);
			};

			if ("onscrollend" in window) {
				window.addEventListener("scrollend", finishJump, {
					once: true,
				});
			} else {
				window.setTimeout(finishJump, 900);
			}
		});
	});

	const chart = document.querySelector("[data-teleop-chart]");
	if (chart) {
		const taskButtons = chart.querySelectorAll("[data-task-option]");
		const cells = chart.querySelectorAll("[data-cell]");
		const panels = document.querySelectorAll("[data-video-panel]");

		const parseMap = (raw) => {
			try {
				return JSON.parse(raw || "{}");
			} catch {
				return {};
			}
		};

		const updateTeleopTask = (taskKey) => {
			taskButtons.forEach((button) => {
				button.classList.toggle(
					"active",
					button.dataset.taskOption === taskKey,
				);
			});

			cells.forEach((cell) => {
				const values = parseMap(cell.dataset.values);
				const raw = values[taskKey];
				const label = cell.querySelector(".metric-value");
				const bar = cell.querySelector("i");
				if (!raw) {
					cell.classList.add("metric-na");
					label.textContent = "N/A";
					bar.style.setProperty("--metric-fill", "0%");
					return;
				}

				cell.classList.remove("metric-na");
				const value = Number(raw);
				const unit = cell.dataset.unit || "";
				const max = Number(cell.dataset.max || 100);
				label.textContent = `${value.toFixed(1)}${unit}`;
				bar.style.setProperty(
					"--metric-fill",
					`${Math.min((value / max) * 100, 100)}%`,
				);
			});

			panels.forEach((panel) => {
				const slot = panel.querySelector("[data-video-map]");
				const video = panel.querySelector("video");
				const taskLabel = panel.querySelector("[data-panel-task]");
				if (!slot || !video) return;

				const videoMap = parseMap(slot.dataset.videoMap);
				const src = videoMap[taskKey];
				const selectedButton = chart.querySelector(
					`[data-task-option="${taskKey}"]`,
				);
				if (taskLabel && selectedButton) {
					taskLabel.textContent = selectedButton.textContent.trim();
				}

				slot.classList.toggle("unavailable", !src);
				if (!src) {
					video.removeAttribute("src");
					video.load();
					return;
				}

				if (video.getAttribute("src") !== src) {
					video.src = src;
					video.load();
				}
				setVideoSpeed(video);
				video.play().catch(() => {});
			});
		};

		taskButtons.forEach((button) => {
			button.addEventListener("click", () =>
				updateTeleopTask(button.dataset.taskOption),
			);
		});

		updateTeleopTask(taskButtons[0]?.dataset.taskOption || "cola");
	}

	const benchmarkSection = document.querySelector("#benchmark");
	if (benchmarkSection) {
		const familyMarks = benchmarkSection.querySelectorAll(
			"[data-family].family-mark",
		);
		const taskCards = benchmarkSection.querySelectorAll(
			"[data-family].task-card",
		);

		const highlightFamily = (family) => {
			benchmarkSection.classList.add("is-family-filtering");
			taskCards.forEach((card) => {
				card.classList.toggle(
					"is-family-highlighted",
					card.dataset.family === family,
				);
			});
			familyMarks.forEach((mark) => {
				mark.classList.toggle(
					"is-family-active",
					mark.dataset.family === family,
				);
			});
		};

		const clearFamilyHighlight = () => {
			benchmarkSection.classList.remove("is-family-filtering");
			taskCards.forEach((card) =>
				card.classList.remove("is-family-highlighted"),
			);
			familyMarks.forEach((mark) =>
				mark.classList.remove("is-family-active"),
			);
		};

		familyMarks.forEach((mark) => {
			mark.addEventListener("mouseenter", () =>
				highlightFamily(mark.dataset.family),
			);
			mark.addEventListener("focus", () =>
				highlightFamily(mark.dataset.family),
			);
			mark.addEventListener("mouseleave", clearFamilyHighlight);
			mark.addEventListener("blur", clearFamilyHighlight);
		});
	}

	// Insight card ↔ VLA bar highlight
	const vlaChart = document.querySelector(".vla-chart");
	document.querySelectorAll("[data-insight]").forEach((card) => {
		const group = card.dataset.insight;
		const bars = document.querySelectorAll(
			`.vla-bar[data-group="${group}"]`,
		);
		card.addEventListener("mouseenter", () => {
			vlaChart?.classList.add("is-filtering");
			bars.forEach((b) => b.classList.add("is-highlighted"));
		});
		card.addEventListener("mouseleave", () => {
			vlaChart?.classList.remove("is-filtering");
			bars.forEach((b) => b.classList.remove("is-highlighted"));
		});
	});
</script>

<style>
