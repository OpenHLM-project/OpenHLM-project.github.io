		--family-body: #9a6a1f;
		--family-body-bg: rgba(154, 106, 31, 0.2);
		--family-body-line: rgba(154, 106, 31, 0.62);
		--family-constraint: #5d7b4a;
		--family-constraint-bg: rgba(93, 123, 74, 0.18);
		--family-constraint-line: rgba(93, 123, 74, 0.62);
	}

