---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
	`${base}${base.endsWith("/") ? "" : "/"}${path}`;
const withBaseIfPresent = (path?: string) => (path ? withBase(path) : "");
const paperUrl = withBase(
	"openhlm/OpenHLM__An_Empirical_Recipe_for_Whole_Body_Humanoid_Loco_Manipulation.pdf",
);
const bibtexCitation = `@article{hu2026openhlm,
  title={OpenHLM: An Empirical Recipe for Whole-Body Humanoid Loco-Manipulation},
  author={Hu, Yingdong and Zhu, Haodong and Zheng, Boyuan and Hu, Yihang and Zhang, Tong and Chen, Zunhao and Zhao, Junming and Nai, Ruiqian and Gao, Yang},
