---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${base.endsWith('/') ? '' : '/'}${path}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={withBase('favicon.png')} />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="OpenHLM: an empirical recipe for whole-body humanoid loco-manipulation."
		/>
		<title>OpenHLM | Whole-Body Humanoid Loco-Manipulation</title>
		<slot name="head" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: #ffffff;
		color: #28132f;
		scroll-behavior: smooth;
	}

	body {
		font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
			"Helvetica Neue", Arial, sans-serif;
	}

	:global(a) {
		color: inherit;
	}
</style>
